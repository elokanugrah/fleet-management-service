# Go API Services
PORT=8080
REQUEST_TIMEOUT=30

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fleet_db
DB_USER=fleet_user
DB_PASSWORD=fleet_pass

# MQTT (Eclipse Mosquitto)
MQTT_BROKER=tcp://mosquitto:1883
MQTT_CLIENT_ID=fleet-backend

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Geofence (titik pusat yang dimonitor sesuai spesifikasi teknis)
GEOFENCE_LAT=-6.2088
GEOFENCE_LNG=106.8456
GEOFENCE_RADIUS_METER=50
